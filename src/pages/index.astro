---
// PUBLIC CATALOG — Server-Side Rendered (SSR).
// Runs on Cloudflare Workers on every request, so prices and stock are always
// fresh. Supports search by name, category filtering and pagination, all driven
// by URL query params (?q=&category=&page=).
import Layout from "../layouts/Layout.astro";
import StoreHeader from "../components/StoreHeader.astro";
import Footer from "../components/Footer.astro";
import ProductCard from "../components/ProductCard.astro";
import SearchBar from "../components/SearchBar.astro";
import Pagination from "../components/Pagination.astro";
import { createServerClient } from "../lib/supabase";
import { PAGE_SIZE, type Product } from "../lib/types";

// --- Read filters from the URL ---------------------------------------------
const params = Astro.url.searchParams;
const q = params.get("q")?.trim() ?? "";
const category = params.get("category")?.trim() ?? "";
const page = Math.max(1, Number(params.get("page")) || 1);

// --- Query Supabase ---------------------------------------------------------
let products: Product[] = [];
let categories: string[] = [];
let totalCount = 0;
let loadError = "";

try {
  const supabase = createServerClient();

  // Distinct categories for the filter dropdown.
  const { data: catRows } = await supabase
    .from("products")
    .select("category")
    .not("category", "is", null);
  categories = [
    ...new Set((catRows ?? []).map((r) => r.category as string)),
  ].sort();

  // Main paginated query with an exact total count.
  let query = supabase.from("products").select("*", { count: "exact" });
  if (q) query = query.ilike("name", `%${q}%`);
  if (category) query = query.eq("category", category);

  const fromRow = (page - 1) * PAGE_SIZE;
  const { data, count, error } = await query
    .order("created_at", { ascending: false })
    .range(fromRow, fromRow + PAGE_SIZE - 1);

  if (error) throw error;
  products = data ?? [];
  totalCount = count ?? 0;
} catch (err) {
  loadError =
    err instanceof Error ? err.message : "Could not load the catalog.";
}

const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));
---

<Layout title="AstroShop — Catalog">
  <StoreHeader />

  <main class="mx-auto w-full max-w-6xl flex-1 px-4 py-8">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-slate-900">Product Catalog</h1>
      <p class="mt-1 text-slate-500">
        Browse our products — rendered on the server on every request.
      </p>
    </div>

    <div class="mb-6">
      <SearchBar q={q} category={category} categories={categories} />
    </div>

    {
      loadError ? (
        <div class="rounded-xl border border-red-200 bg-red-50 p-6 text-center">
          <p class="font-semibold text-red-700">Could not load the catalog</p>
          <p class="mt-1 text-sm text-red-600">{loadError}</p>
          <p class="mt-2 text-xs text-red-500">
            Check that your Supabase environment variables are configured.
          </p>
        </div>
      ) : products.length === 0 ? (
        <div class="rounded-xl border border-slate-200 bg-white p-12 text-center">
          <p class="text-4xl">🔍</p>
          <p class="mt-2 font-semibold text-slate-700">No products found</p>
          <p class="mt-1 text-sm text-slate-500">
            {q || category
              ? "Try a different search or clear the filters."
              : "The catalog is empty. Add products from the admin portal."}
          </p>
        </div>
      ) : (
        <>
          <p class="mb-4 text-sm text-slate-500">
            {totalCount} product{totalCount === 1 ? "" : "s"} found
            {q && ` for “${q}”`}
            {category && ` in “${category}”`}
          </p>

          <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
            {products.map((product) => (
              <ProductCard product={product} />
            ))}
          </div>

          <div class="mt-8">
            <Pagination
              currentPage={page}
              totalPages={totalPages}
              q={q}
              category={category}
            />
          </div>
        </>
      )
    }
  </main>

  <Footer />
</Layout>
