// Storefront navigation bar. Rendered on the SSR (public) pages.
---

<header class="sticky top-0 z-10 border-b border-slate-200 bg-white/90 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
    <a href="/" class="text-xl font-bold text-brand-600">⚡ AstroShop</a>
    <div class="flex items-center gap-2 text-sm">
      <a
        href="/"
        class="rounded-lg px-3 py-1.5 font-medium text-slate-600 hover:bg-slate-100"
      >
        Catalog
      </a>
      <a
        href="/admin"
        class="rounded-lg bg-brand-600 px-3 py-1.5 font-medium text-white hover:bg-brand-700"
      >
        Admin
      </a>
    </div>
  </nav>
</header>
