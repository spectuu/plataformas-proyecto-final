# --- Supabase credentials ---------------------------------------------------
# Copy this file to `.env` and fill in the values from your Supabase project:
#   Supabase Dashboard -> Project Settings -> API
#
# Both values are PUBLIC by design:
#   - The anon key is meant to be exposed in the browser.
#   - It only grants the access allowed by Row Level Security (RLS) policies.
#   - The privileged `service_role` key is NEVER used in this project.
#
# The `PUBLIC_` prefix tells Astro to make these available to client-side code.
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
